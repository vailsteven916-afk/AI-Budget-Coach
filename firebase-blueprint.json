{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile data including balance and onboarding status",
      "type": "object",
      "properties": {
        "balance": { "type": "number" },
        "hasCompletedOnboarding": { "type": "boolean" }
      }
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "date": { "type": "string" },
        "note": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["amount", "type", "category", "date"]
    },
    "Goal": {
      "title": "Goal",
      "description": "A savings goal",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "targetAmount": { "type": "number" },
        "currentAmount": { "type": "number" },
        "deadline": { "type": "string" },
        "icon": { "type": "string" }
      },
      "required": ["title", "targetAmount", "currentAmount", "deadline", "icon"]
    },
    "Challenge": {
      "title": "Challenge",
      "description": "A financial challenge",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "progress": { "type": "number" },
        "total": { "type": "number" },
        "completed": { "type": "boolean" }
      },
      "required": ["title", "description", "progress", "total", "completed"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profiles"
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "User transactions"
    },
    "/users/{userId}/goals/{goalId}": {
      "schema": { "$ref": "#/entities/Goal" },
      "description": "User goals"
    },
    "/users/{userId}/challenges/{challengeId}": {
      "schema": { "$ref": "#/entities/Challenge" },
      "description": "User challenges"
    }
  }
}
